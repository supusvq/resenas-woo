# Proveedor recomendado para produccion ligera:
# google_business_profile | apify | selenium_legacy | demo
MRG_REVIEW_PROVIDER=google_business_profile
MRG_SAAS_DB_PATH=mrg_saas.sqlite3

# Compatibilidad antigua. Si no existe MRG_REVIEW_PROVIDER:
# MRG_IMPORT_MODE=upstream equivale a selenium_legacy.
# MRG_IMPORT_MODE=demo equivale a demo.
# MRG_IMPORT_MODE=

# Google Business Profile API
# Requiere acceso OAuth a la ficha del negocio.
MRG_GBP_ACCESS_TOKEN=
MRG_GBP_REFRESH_TOKEN=
MRG_GBP_CLIENT_ID=
MRG_GBP_CLIENT_SECRET=
MRG_GBP_TOKEN_URL=https://oauth2.googleapis.com/token
MRG_GBP_ACCOUNT_ID=
MRG_GBP_LOCATION_ID=
MRG_GBP_PLACE_NAME=
MRG_GBP_API_BASE=https://mybusiness.googleapis.com/v4

# OAuth central para conectar cualquier WordPress cliente.
MRG_GOOGLE_CLIENT_ID=
MRG_GOOGLE_CLIENT_SECRET=
MRG_GOOGLE_REDIRECT_URI=https://scraper.supufactory.es/v1/google/oauth/callback
MRG_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
MRG_GBP_ACCOUNT_API_BASE=https://mybusinessaccountmanagement.googleapis.com/v1
MRG_GBP_BUSINESS_INFO_API_BASE=https://mybusinessbusinessinformation.googleapis.com/v1

# Apify
# El actor exacto se configura aqui cuando se elija proveedor/actor.
MRG_APIFY_TOKEN=
MRG_APIFY_ACTOR_ID=
MRG_APIFY_API_BASE=https://api.apify.com/v2
MRG_APIFY_TIMEOUT=180

# Selenium legado: mantener solo como fallback temporal.
MRG_UPSTREAM_API_URL=http://127.0.0.1:8001
MRG_UPSTREAM_API_KEY=
MRG_UPSTREAM_TIMEOUT=180
